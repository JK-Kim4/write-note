{
  "permissions": {
    "deny": [
      "Bash(psql *)",
      "Bash(pg_dump *)",
      "Bash(pg_restore *)",
      "Bash(pg_basebackup *)",
      "Bash(redis-cli *)",
      "Bash(flyway *)",
      "Bash(liquibase *)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)",
      "Read(.env.development)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push *)",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/sync-vault-on-push.sh",
            "statusMessage": "sync-vault 트리거 신호 주입 중..."
          }
        ]
      }
    ]
  }
}
