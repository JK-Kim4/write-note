# write-note backend — local dev env vars sample
# Phase 1B Backend Auth Foundation (spec 003)
# Copy this file to .env.local and fill in real values (DO NOT commit .env.local).

# --- JWT ---
# Required. Min 32 bytes (base64-encoded). HS256 signing key.
JWT_SECRET=

# --- Kakao OAuth (Phase 1B US2) ---
# Required only when actually exercising Kakao OAuth locally.
# Register your app at https://developers.kakao.com → 내 애플리케이션 → REST API 키.
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8080/login/oauth2/code/kakao

# --- Mail (Phase 1B — local profile uses log impl, these are for SMTP fallback only) ---
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=no-reply@write-note.local
MAIL_BASE_URL=http://localhost:8080

# --- Frontend (URL fragment redirect target for OAuth success) ---
FRONTEND_BASE_URL=http://localhost:3000
